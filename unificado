  # Cria a variável "Ind Portador Defic", preenchida
  # conforme as observações as observações das
  # variáveis "tipodedeficiência" e "tipodedeficiência"
  caged[, "Ind Portador Defic"] <-
    ifelse(caged[, "tipodedeficiência"] == 0, 0,
           ifelse(caged[, "tipodedeficiência"] == 9, 9,
                  1))
  
  
  # Converte a variável para factor
  caged[, "sexo"] <- as.factor(caged[, "sexo"])
  
  # Substitui toda ocorrência de 3, por 2
  caged[, "sexo"] <- fct_collapse(caged[, "sexo"],
                                  "2" = "3")
  
  # Converte a variável para factor
  caged[, "tipoestabelecimento"] <-
    as.factor(caged[, "tipoestabelecimento"])
  
  # Substitui toda ocorrência de 5, por 3 e toda
  # ocorrência de 3, por 5
  caged[, "tipoestabelecimento"] <-
    fct_collapse(caged[, "tipoestabelecimento"],
                 "3" = "5",
