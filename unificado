#                      CNAE

### Os procedimentos abaixo visam preparar a variável
### "subclasse" para servir de chave para o merge
### com a planilha CNAE
{
  # Converte o objeto para a classe "data.frame"
  caged <- as.data.frame(caged)
  
  # Converte a variável para a classe 'character'
  caged[, "subclasse"] <- as.character(caged[, "subclasse"])
  
  # Adiciona um "0" a esquerda em todas as
  # observações com 6 dígitos. Este procedimento
  # é necessário pois, ao importar os dados, o R
  # interpreta os códigos da subclasse CNAE como
  # sendo da classe "númeric", o que  provoca a
  # eliminação dos zeros à esquerda
  caged[, "subclasse"] <-
    ifelse(str_count(caged[, "subclasse"]) == 6,
           paste(0, caged[, "subclasse"], sep = ""),
           caged[, "subclasse"])
  
}

# Importa a planilha de conversão da CNAE versão 2.0,
# 2.1 e 2.2 para a 2.3
cnae_convert <-
  data.frame(
    fread(
      "C:/Users/super/Desktop/pbh/bases/Transição CNAE.txt",
      stringsAsFactors = TRUE
    )
  )

# Elimina todas as ocorrências de "/"
cnae_convert$CNAE_2.0 <- gsub("/", "", cnae_convert$CNAE_2.0)
cnae_convert$CNAE_2.1 <- gsub("/", "", cnae_convert$CNAE_2.1)
cnae_convert$CNAE_2.2 <- gsub("/", "", cnae_convert$CNAE_2.2)
cnae_convert$CNAE_2.3 <- gsub("/", "", cnae_convert$CNAE_2.3)

# Elimina todas as ocorrências de "-"
cnae_convert$CNAE_2.0 <- gsub("-", "", cnae_convert$CNAE_2.0)
cnae_convert$CNAE_2.1 <- gsub("-", "", cnae_convert$CNAE_2.1)
cnae_convert$CNAE_2.2 <- gsub("-", "", cnae_convert$CNAE_2.2)
cnae_convert$CNAE_2.3 <- gsub("-", "", cnae_convert$CNAE_2.3)

# Insere uma coluna chamada "CNAE_2.0", com os códigos
# correspondentes da CNAE versão 2.3
caged <-
  merge(
    caged,
    select(cnae_convert, CNAE_2.0,
           CNAE_2.3),
    by.x = c("subclasse"),
    by.y = c("CNAE_2.0"),
    all.x = TRUE
  )

# Remove objetos
rm(cnae_convert)

# Substitui os códigos antigos da CNAE 2.0 pelos
# respectivos códigos da CNAE 2.3
caged$subclasse <-
  ifelse(is.na(caged[, length(caged)]),
         caged$subclasse, caged[, length(caged)])

# Substitui as do código 8630505 pelo 8630504.
# Esta alteração foi realizada manualmente, pois
# não consta o código 8630505 em nenhuma das versões
# CNAE 2.0, 2.1, 2.2 ou 2.3, apesar de haver
# ocorrência dele no Novo CAGED
caged$subclasse <-
  gsub("8630505",
       "8630504",
       caged$subclasse)

# Elimina variável do conjunto de dados
caged[, length(caged)] <- NULL

# Importa a planilha com as demais hierarquias CNAE
cnae <-
  fread(
    "C:/Users/super/Desktop/pbh/bases/cnae_2.3.txt",
    stringsAsFactors = TRUE
  )

# Elimina variáveis desnecessárias
cnae$ordem <- NULL
cnae$denominação <- NULL
cnae$V8 <- NULL

# Elimina todas as linhas com observações vazias na
# variável 'subclasse''
cnae <- filter(cnae, subclasse != "")

# Elimina todas as ocorrências de "-" e "/" nas variáveis
# 'subclasse'
cnae$subclasse <- gsub("-", "", cnae$subclasse)
cnae$subclasse <- gsub("/", "", cnae$subclasse)

# Converte a classe da variável para "character"
cnae$subclasse <- as.character(cnae$subclasse)

# Insere as observações do conjunto de dados "cnae" no
# conjunto de dados "caged", conforme correspondência
# da variável "subclasse", comum aos dois conjuntos de
# dados

caged <-
  left_join(caged, cnae, by = "subclasse")

# Remove objetos
rm(cnae)

